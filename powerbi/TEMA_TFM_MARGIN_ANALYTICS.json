{
  "name": "TFM Margin Analytics",
  "dataColors": [
    "#1F4E79",
    "#2F7D32",
    "#F2A541",
    "#C0392B",
    "#5B5F97",
    "#4C78A8",
    "#54A24B",
    "#E45756",
    "#72B7B2",
    "#B279A2"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F2933",
  "tableAccent": "#1F4E79",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#1F2933"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "labels": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "color": {
              "solid": {
                "color": "#1F2933"
              }
            }
          }
        ],
        "background": [
          {
            "show": false,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontSize": 20,
            "fontFamily": "Segoe UI Semibold",
            "color": {
              "solid": {
                "color": "#1F4E79"
              }
            }
          }
        ],
        "categoryLabels": [
          {
            "fontSize": 10,
            "fontFamily": "Segoe UI",
            "color": {
              "solid": {
                "color": "#52616B"
              }
            }
          }
        ]
      }
    }
  }
}

